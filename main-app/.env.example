# BN Agent — 运行配置示例（复制为 .env 后填写）
RUST_LOG=info

# ── LLM ───────────────────────────────────────────────
LLM_API_KEY=your_api_key
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_THINKING=disabled
LLM_MAX_TOKENS=8192
LLM_MAX_HISTORY=20
LLM_MAX_TOOL_ROUNDS=20

# ── 插件加载 ──────────────────────────────────────────
# PLUGIN_LOAD=logger-plugin,time-plugin,tg-im-plugin
# PLUGIN_SKIP=

# ── 本地生图 (ComfyUI) ───────────────────────────────
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_OUTPUT_DIR=output
# IMAGE_GEN_OUTPUT_DIR=temp_images

# ── 图片 / 视频理解（可选，独立模型） ─────────────────
# IMAGE_MODEL=
# IMAGE_API_KEY=
# IMAGE_BASE_URL=
# VIDEO_MODEL=
# VIDEO_API_KEY=
# VIDEO_BASE_URL=

# ── Telegram ──────────────────────────────────────────
# TG_BOT_TOKEN=
# TG_PROXY_URL=

# ── 主动追问 (proactive-plugin) ───────────────────────
# PROACTIVE_MODE=auto
# PROACTIVE_LOOP_INTERVAL=15

# ── ASR / TTS ─────────────────────────────────────────
# ASR_API_KEY=
# ASR_BASE_URL=
# ASR_MODEL=
# TTS_API_KEY=
# TTS_BASE_URL=
# TTS_MODEL=
